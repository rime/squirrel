#!/bin/bash

set -e

project_file=Squirrel.xcodeproj/project.pbxproj
test -f "${project_file}"

# 定義固定的錨點資訊（保持與原專案文件一致，供 sed 尋找定位）
a_build="448363DE25BDBBED0022C7BA"
a_ref="448363DA25BDBBBF0022C7BA"
a_file="zhuyin.yaml"

a_lib_build="2C6B9F9D2BCD086700E327DF"
a_lib_ref="2C6B9F9A2BCD086700E327DF"
a_lib_file="librime-lua.dylib"

# 函數：生成唯一且不重複的 24 位十六進制大寫 ID
generate_uuid() {
    while true; do
        local uuid=$(openssl rand -hex 12 | tr '[:lower:]' '[:upper:]')
        # 確保這個 ID 沒在 project.pbxproj 中出現過
        if ! grep -q "$uuid" "${project_file}"; then
            echo "$uuid"
            return
        fi
    done
}

obj_entry() {
    echo "$1 /* $3 in Copy Shared Support Files */ = {isa = PBXBuildFile; fileRef = $2 /* $3 */; };"
}

copy_files_entry() {
    echo "$1 /* $3 in Copy Shared Support Files */,"
}

file_ref_entry() {
    echo "$2 /* $3 */ = {isa = PBXFileReference; fileEncoding = 4; lastKnownFileType = text; name = $3; path = data/plum/$3; sourceTree = \"<group>\"; };"
}

group_entry() {
    echo "$2 /* $3 */,"
}

lib_entry() {
    echo "$1 /* $3 in Copy Rime plugins */ = {isa = PBXBuildFile; fileRef = $2 /* $3 */; settings = {ATTRIBUTES = (CodeSignOnCopy, ); }; };"
}

lib_ref_entry() {
    echo "$2 /* $3 */ = {isa = PBXFileReference; lastKnownFileType = \"compiled.mach-o.dylib\"; name = \"$3\"; path = \"lib/rime-plugins/$3\"; sourceTree = \"<group>\"; };"
}

frameworks_phase_entry() {
    echo "$1 /* $3 in Copy Rime plugins */,"
}

add_line() {
    # 對傳入的錨點與新行進行轉義，防止路徑中的 / 或註釋中的 * 破壞 sed 語法
    local escaped_anchor=$(sed 's/\//\\\//g; s/\*/\\*/g' <<< "${1}")
    local escaped_new=$(sed 's/\//\\\//g' <<< "${2}")

    # 使用 s 命令替換：
    # \1 捕獲行首的縮進（空格/Tab），\2 捕獲錨點內容
    # 替換爲：保留原行內容 (\1\2) + 換行 + 相同的縮進 (\1) + 新行內容
    sed -i '' "s/^\([[:space:]]*\)\(${escaped_anchor}\)$/\1\2\\
\1${escaped_new}/" "${project_file}"
}

add_file() {
    local file="$1"
    # 動態生成全新且唯一的 ID
    local new_id=$(generate_uuid)
    local new_refid=$(generate_uuid)
    local anchor_line
    local new_line

    anchor_line="$(obj_entry "$a_build" "$a_ref" "$a_file")"
    new_line="$(obj_entry "${new_id}" "${new_refid}" "${file}")"
    add_line "${anchor_line}" "${new_line}"

    anchor_line="$(copy_files_entry "$a_build" "$a_ref" "$a_file")"
    new_line="$(copy_files_entry "${new_id}" "${new_refid}" "${file}")"
    add_line "${anchor_line}" "${new_line}"

    anchor_line="$(file_ref_entry "$a_build" "$a_ref" "$a_file")"
    new_line="$(file_ref_entry "${new_id}" "${new_refid}" "${file}")"
    add_line "${anchor_line}" "${new_line}"

    anchor_line="$(group_entry "$a_build" "$a_ref" "$a_file")"
    new_line="$(group_entry "${new_id}" "${new_refid}" "${file}")"
    add_line "${anchor_line}" "${new_line}"
}

add_lib() {
    local lib="$1"
    local new_lib_id=$(generate_uuid)
    local new_lib_refid=$(generate_uuid)
    local anchor_lib_line
    local new_lib_line

    anchor_lib_line="$(lib_entry "$a_lib_build" "$a_lib_ref" "$a_lib_file")"
    new_lib_line="$(lib_entry "${new_lib_id}" "${new_lib_refid}" "${lib}")"
    add_line "${anchor_lib_line}" "${new_lib_line}"

    anchor_lib_line="$(lib_ref_entry "$a_lib_build" "$a_lib_ref" "$a_lib_file")"
    new_lib_line="$(lib_ref_entry "${new_lib_id}" "${new_lib_refid}" "${lib}")"
    add_line "${anchor_lib_line}" "${new_lib_line}"

    anchor_lib_line="$(frameworks_phase_entry "$a_lib_build" "$a_lib_ref" "$a_lib_file")"
    new_lib_line="$(frameworks_phase_entry "${new_lib_id}" "${new_lib_refid}" "${lib}")"
    add_line "${anchor_lib_line}" "${new_lib_line}"
}

data_files=(
    $(ls data/plum/* | xargs basename)
)

lib_files=(
    $(ls lib/rime-plugins/* | xargs basename)
)

for file in "${data_files[@]}"
do
    if grep -Fq " ${file} " "${project_file}"
    then
        echo "found ${file}"
        continue
    fi
    echo "adding ${file} to ${project_file}"
    add_file "${file}"
done

for lib in "${lib_files[@]}"
do
    if grep -Fq " ${lib} " "${project_file}"
    then
        echo "found ${lib}"
        continue
    fi
    echo "adding ${lib} to ${project_file}"
    add_lib "${lib}"
done
